# ============================================================
# Nova Learn — Student Learning Dashboard
# Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file — it is already in .gitignore.
# ============================================================

# ----------------------------------------------------------
# SUPABASE (Required for cloud database mode)
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ----------------------------------------------------------

# Your Supabase project URL (format: https://<project-ref>.supabase.co)
VITE_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"

# Your Supabase anonymous/public key (safe to use in browser)
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Your Supabase service role key (server-side only — keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ----------------------------------------------------------
# GEMINI AI (Optional — for AI-powered features)
# Get your key from: https://aistudio.google.com/apikey
# ----------------------------------------------------------
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ----------------------------------------------------------
# APP CONFIG (Optional)
# ----------------------------------------------------------

# The public URL where this app is hosted (used for OAuth callbacks, self-referential links)
APP_URL="http://localhost:3000"

# ----------------------------------------------------------
# NOTE: If VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are
# left empty, the app runs in offline mode using localStorage
# as a fully-functional mock database — no setup required.
# ----------------------------------------------------------
